rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. PRIMARY USER DATA PROTECTION
    // Only the authenticated user that owns the document can read or write to it.
    // This absolutely prevents "cross-user" data hacks.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Protect any subcollections (like transactions) automatically
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // 2. USERNAME REGISTRY PROTECTION
    // Anyone can read this to check if a username exists (during login/onboarding).
    // Writing is strictly allowed only if the authenticated user matches the userId being registered.
    match /usernames/{username} {
      allow read: if true; 
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Prevent updating or deleting someone else's username mapping
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // 3. GLOBAL LOCKDOWN
    // Deny all other access by default to avoid accidental leaks
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
